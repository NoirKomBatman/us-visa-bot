# US Visa Bot Configuration
# Copy this file to .env and fill in your actual values

# Your credentials for https://ais.usvisa-info.com/
EMAIL=your.email@example.com
PASSWORD=your_password_here

# Locale segment - the full {lang}-{country} part of the URL when rescheduling.
# URL format: https://ais.usvisa-info.com/{COUNTRY_CODE}/niv/...
# Examples: 'en-us' (US, English), 'fr-fr' (France), 'ru-kz' (Kazakhstan, Russian)
COUNTRY_CODE=en-us

# Schedule ID - found in the URL when trying to reschedule manually
# URL format: https://ais.usvisa-info.com/en-{COUNTRY_CODE}/niv/schedule/{SCHEDULE_ID}/continue_actions
SCHEDULE_ID=12345678

# Facility ID - found in network calls when selecting a new date or inspecting the selector
# Examples: Paris is 44
# URL format: https://ais.usvisa-info.com/en-{COUNTRY_CODE}/niv/schedule/{SCHEDULE_ID}/appointment/address/{FACILITY_ID}
FACILITY_ID=44

# Telegram bot token - create a bot via @BotFather and copy the token it gives you
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyz

# Telegram chat ID - the chat the bot should message.
# Send your bot a message, then open
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates and read result[].message.chat.id
TELEGRAM_CHAT_ID=987654321

# Refresh delay in seconds between checks (optional, defaults to 3)
REFRESH_DELAY=3
